# =========================
# Dependencies (NEVER include in image build context)
# =========================
node_modules
npm-debug.log
yarn-error.log

# =========================
# Environment files (CRITICAL - security)
# =========================
.env
.env.*
!.env.example

# =========================
# Logs
# =========================
*.log

# =========================
# OS / Editor files
# =========================
.DS_Store
.vscode/
.idea/

# =========================
# Git metadata (not needed in image)
# =========================
.git
.gitignore

# =========================
# Build outputs (avoid copying stale builds)
# =========================
build
dist